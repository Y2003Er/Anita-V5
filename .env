# DATABASE_URL is required for persistent PostgreSQL-backed sessions.
# On Railway, this is automatically provided when you attach a Postgres plugin.
# Format: postgresql://user:password@host:port/dbname
# Without this variable the bot falls back to local file-based sessions (ephemeral).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: override the session identifier stored in the database (default: anita_v5_session)
# SESSION_DB_ID=anita_v5_session

# Optional: override the local session directory path (default: ./session)
# SESSION_DIR=./session

